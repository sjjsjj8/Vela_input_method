          <img src="./assets/arc/{{lang}}.png" style="position: absolute;top:0px;left:9px;width: 48px;height: 42px;" @click="onBtnClick('lang')" show="{{downFlag==='' && !numFlag}}" />
          <img src="./assets/arc/back2.png" style="position: absolute;top:0px;left:9px;width: 48px;height: 42px;" @click="onBtnClick('switchCn')" show="{{numFlag && lang==='cn'}}" />
          <img src="./assets/arc/123.png" style="position: absolute;left: 70px;top: 0px;width: 52px;height: 42px;" @click="onBtnClick('switchNum')" show="{{downFlag==='' && !numFlag && lang==='cn'}}" />
          <img src="./assets/arc/bigA.png" style="position: absolute;top:0px;left:72px;width:48px;height:42px;" @click="onBtnClick('switchLow')" show="{{downFlag==='' && upperFlag && lang==='en'}}" />
          <img src="./assets/arc/a.png" style="position: absolute;top:0px;left:72px;width:48px;height:42px;" @click="onBtnClick('switchUpper')" show="{{downFlag==='' && !upperFlag && lang==='en'}}" />
          <img src="./assets/arc/del.png" style="position: absolute;left: 135px;top: 0px;width: 48px;height: 42px;" @touchstart="onDelStart" @touchend="onDelEnd" />
        </div>
        <!-- 这里使用show会导致每次输入都会加载全部候选列表，很卡 -->
        <div style="position: absolute;top: 47px;width: 100%;height: 263px;background-color: black;" if="{{downFlag==='down'}}">
          <div style="position: absolute;left: {{(screenWidth - 192)/2}}px;width: 192px;height: 263px;"> 
            <list static class="list66">
              <list-item type="waitingRows66" class="item66" for="{{itemArray in resultList2}}">
                <div class="item column center" for="{{item in itemArray}}">
                  <input class="calbtn0" type="button" value="{{item}}" @click="onRsSelect(item)" />
                </div>
              </list-item>
            </list>
            <img static style="position: absolute;top:196px;left:56px;width: 80px;height: 60px;" src="./assets/arc/up2.png" @click="onBtnClick('down')" />
          </div>
        </div>
      </div>
    </div>
  </div>
</template>

<script>
import vibrator from "@system.vibrator";
import device from '@system.device'
import { SimpleInputMethod } from "./assets/dicUtil.js";

const KEYBOARD_KEYS = {
  full: [["Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P"], ["A", "S", "D", "F", "G", "H", "J", "K", "L"], ["Z", "X", "C", "V", "B", "N", "M"]],
  sign: [["1", "2", "3", "4", "5", "6", "7", "8", "9", "0"], ["~", "!", "@", "#", "%", "^", "&", "*", "?", "/"], ["(", ")", "-", "_", ":", ";", "'", "\"", "."]],
  sign62: [["2", "3", "4", "5", "6", "7", "8", "9"], ["!", "@", "#", "%", "^", "&", "*"], [")", "-", "_", ":", ";"]],
  full62: [["W", "E", "R", "T", "Y", "U", "I", "O"], ["S", "D", "F", "G", "H", "J", "K"], ["X", "C", "V", "B", "N"]],
  t9: [["abc", "def"], ["ghi", "jkl", "mno"], ["pqrs", "tuv", "wxyz"]],
};
const _t9Keys = new Set(["abc","def","ghi","jkl","mno","pqrs","tuv","wxyz"]);
const _t9LetterCache = new Map();
for (const k of _t9Keys) { _t9LetterCache.set(k, k.split("")); }
let _delTimer = null;
const _seenSet = new Set();

export default {
  props: { hide: { default: true }, keyboardtype: { default: "QWERTY" }, maxlength: { default: 5 }, vibratemode: { default: "light" }, screentype: { default: "circle" } },
  data: {
    cval: "", resultList: [""], resultList2: [[]], t9History: [],
    waitingList: [""], waitingIndex: 0,
    downFlag: "", lang: "cn", numFlag: false, upperFlag: false, cvalList: [0, 1, 2, 3, 4],
    percent67: 52, percent66: 0, screenWidth: 336, keys: KEYBOARD_KEYS, _isDestroyed: false, touchStartY: 0,
    lastInputChar: "", hintCount: 0
  },
  onInit() {
    this._isDestroyed = false;
    if (this.maxlength) {
      this.cvalList = Array.from({ length: this.maxlength }, (_, i) => i);
    }
    if (this.screentype === "rect" || this.screentype === "pill-shaped") {
      this.adjustScreenWidth();
    }
    this.$watch("hide", "watchHidePropsChange");
    this.$watch("maxlength", "watchMaxLengthPropsChange");
  },
  onDestroy() { this._isDestroyed = true; if (_delTimer) { clearInterval(_delTimer); _delTimer = null; } },
  addAllTxt(txt) { this.$emit("complete", { content: txt }); },
  onRsSelect(txt) {
    this.onVibrate();
    if (txt) {
      const hints = SimpleInputMethod.getWordHints(this.lastInputChar);
      if (hints && hints.includes(txt[0])) { this.hintCount++; }
      else { this.hintCount = 0; }
      this.lastInputChar = txt[txt.length - 1];
    }
    else { this.lastInputChar = ""; this.hintCount = 0; }
    this.cval = "";
    this.t9History = [];
    this.addAllTxt(txt);
    this.clearWaiting();
    this.resetReslutList();
    this.downFlag = "";
  },
  onBtnClick(sign) {
    this.onVibrate();
    switch (sign) {
      case "AC": this.cval = ""; this.t9History = []; this.clearWaiting(); this.resetReslutList(); break;
      case "lang": this.lang = this.lang === "cn" ? "en" : "cn"; this.cval = ""; this.t9History = []; this.clearWaiting(); this.resetReslutList(); break;
      case "D":
        this.lastInputChar = ""; this.hintCount = 0;
        if (this.t9History.length > 0) { this.t9History.pop(); this._syncWaiting(); this.resetReslutList(); }
        else if (this.cval.length > 0) { this.cval = this.cval.slice(0, -1); this.resetReslutList(); }
        else { this.$emit("delete", {}); }
        break;
      case "space": this.addAllTxt(" "); break;
      case "down": this.downFlag = this.downFlag === "down" ? "" : "down"; break;
      case "select":
        if (this.t9History.length > 0) {
          let confirmed = "";
          for (let i = 0; i < this.t9History.length; i++) { confirmed += this.t9History[i].letters[this.t9History[i].index]; }
          if (this.lang === "cn") { this.cval += confirmed; }
          else { this.addAllTxt(this.upperFlag ? confirmed.toUpperCase() : confirmed.toLowerCase()); }
          this.lastInputChar = confirmed[confirmed.length - 1] || "";
          this.t9History = []; this.clearWaiting(); this.resetReslutList();
        }
        break;
      case "switchNum": this.numFlag = true; this.cval = ""; this.t9History = []; this.clearWaiting(); this.resetReslutList(); break;
      case "switchCn": this.numFlag = false; break;
      case "switchUpper": this.upperFlag = true; break;
      case "switchLow": this.upperFlag = false; break;
      default:
        if (sign.length === 1) { this.addAllTxt(sign); }
        else {
          if (this.t9History.length > 0) {
            let confirmed = "";
            for (let i = 0; i < this.t9History.length; i++) { confirmed += this.t9History[i].letters[this.t9History[i].index]; }
            if (this.lang === "cn") { this.cval += confirmed; }
            else { this.addAllTxt(this.upperFlag ? confirmed.toUpperCase() : confirmed.toLowerCase()); }
            this.t9History = [];
          }
          this.waitingIndex = 0; this.waitingList = _t9LetterCache.get(sign) || sign.split("");
          this.resetReslutList();
        }
        break;
    }
  },
  clearWaiting() { this.t9History = []; this._syncWaiting(); },
  _syncWaiting() {
    if (this.t9History.length > 0) {
      const last = this.t9History[this.t9History.length - 1];
      this.waitingList = last.letters;
      this.waitingIndex = last.index;
    } else { this.waitingList = [""]; this.waitingIndex = 0; }
  },
  resetReslutList() {
    if (this.screentype != "circle") { this.$element("cvalWaiting")?.scrollTo({ top: 0, left: 0, behavior: "smooth" }); }
    if (this.lang != "cn") { this.resultList = [""]; this.setResultListAll(); return; }
    const maxPre = parseInt(this.maxlength) || 6;
    if (this.t9History.length > 0) {
      const groups = SimpleInputMethod.getT9Matches(this.t9History, this.cval);
      if (!groups.length) { this.resultList = [""]; this.resultList2 = [[]]; return; }
      _seenSet.clear();
      const preview = [];
      let g;
      for (g = 0; g < groups.length && preview.length < maxPre; g++) {
        const ch = groups[g].c[0];
        if (ch && ch !== ' ' && !_seenSet.has(ch)) { _seenSet.add(ch); preview.push(ch); }
      }
      if (preview.length < maxPre) {
        for (let round = 1; round < 10 && preview.length < maxPre; round++) {
          for (g = groups.length - 1; g >= 0 && preview.length < maxPre; g--) {
            const ch = groups[g].c[round];
            if (ch && ch !== ' ' && !_seenSet.has(ch)) { _seenSet.add(ch); preview.push(ch); }
          }
        }
      }
      const expandChars = preview.slice();
      for (let round = 0; round < 20 && expandChars.length < 20; round++) {
        for (g = 0; g < groups.length && expandChars.length < 20; g++) {
          const ch = groups[g].c[round];
          if (ch && ch !== ' ' && !_seenSet.has(ch)) { _seenSet.add(ch); expandChars.push(ch); }
        }
      }
      if (this.lastInputChar) {
        const hints = SimpleInputMethod.getWordHints(this.lastInputChar);
        for (let h = hints.length - 1; h >= 0; h--) {
          if (!_seenSet.has(hints[h])) { _seenSet.add(hints[h]); preview.unshift(hints[h]); expandChars.unshift(hints[h]); }
        }
        if (preview.length > maxPre) { preview.length = maxPre; }
      }
      this.resultList = preview.length ? preview : [""];
      this.resultList2 = [[]];
      for (let i = 0; i < expandChars.length; i += 8) { this.resultList2.push(expandChars.slice(i, i + 8)); }
    } else {
      const hanzi = SimpleInputMethod.getHanzi(this.cval);
      this.resultList = hanzi?.[0] || [""];
      if (this.lastInputChar) {
        const hints = SimpleInputMethod.getWordHints(this.lastInputChar);
        _seenSet.clear();
        for (let i = 0; i < this.resultList.length; i++) _seenSet.add(this.resultList[i]);
        const extra = [];
        for (let i = 0; i < hints.length; i++) { if (!_seenSet.has(hints[i])) { _seenSet.add(hints[i]); extra.push(hints[i]); } }
        if (extra.length) { this.resultList = extra.concat(this.resultList); }
      }
      this.setResultListAll();
    }
  },
  setResultListAll() {
    this.resultList2 = [[]];
    for (let i = 0; i < this.resultList.length; i += 8) {
      this.resultList2.push(this.resultList.slice(i, i + 8));
    }
  },
  onSelect(num) {
    this.$emit("keyDown", { content: num });
    if (this.keyboardtype === "T9" && this.screentype !== "pill-shaped") {
      this.onVibrate();
      if (_t9Keys.has(num) && !this.numFlag) {
        this.lastInputChar = ""; this.hintCount = 0;
        const last = this.t9History[this.t9History.length - 1];
        if (this.lang === "cn") {
          if (last && last.key === num) {
            last.index = (last.index + 1) % last.letters.length;
          } else {
            if (this.t9History.length < 6) { this.t9History.push({ key: num, letters: _t9LetterCache.get(num), index: 0 }); }
          }
        } else {
          if (last && last.key === num) {
            last.index++;
            if (last.index >= last.letters.length) { last.index = 0; }
          } else {
            if (this.t9History.length > 0) {
              let confirmed = "";
              for (let i = 0; i < this.t9History.length; i++) { confirmed += this.t9History[i].letters[this.t9History[i].index]; }
              this.addAllTxt(this.upperFlag ? confirmed.toUpperCase() : confirmed.toLowerCase());
              this.lastInputChar = confirmed[confirmed.length - 1] || "";
            }
            this.t9History = [{ key: num, letters: _t9LetterCache.get(num), index: 0 }];
          }
        }
        this._syncWaiting();
      } else { this.onBtnClick(num); return; }
      this.resetReslutList();
      return;
    }
    this.onVibrate();
    this.lastInputChar = ""; this.hintCount = 0;
    if (this.lang === "cn" && !this.numFlag) { this.cval += num.toLowerCase(); }
    else if (this.lang === "en" && !this.numFlag) { this.addAllTxt(this.upperFlag ? num.toUpperCase() : num.toLowerCase()); }
    else { this.addAllTxt(num); }
    this.resetReslutList();
  },
  onSelectWaiting(num) {
    this.onVibrate();
    if (this.t9History.length > 0) {
      this.t9History[this.t9History.length - 1].index = num;
      if (this.lang !== "cn") {
        const last = this.t9History[this.t9History.length - 1];
        this.addAllTxt(this.upperFlag ? last.letters[num].toUpperCase() : last.letters[num].toLowerCase());
        this.lastInputChar = last.letters[num];
        this.clearWaiting(); this.resetReslutList(); return;
      }
    }
    this._syncWaiting();
    this.resetReslutList();
  },
  watchHidePropsChange(newV) { this.$emit("visibilityChange", { visible: newV }); },
  watchMaxLengthPropsChange(newV) { if (newV) { this.cvalList = Array.from({ length: newV }, (_, i) => i); } },
  onVibrate() { if (this.vibratemode) { vibrator.vibrate({ mode: this.vibratemode }); } },
  handelScroll(event) {
    this.percent67 = Math.min(100, parseInt((event.scrollX / 636) * 100 + 52.8));
    this.percent66 = Math.min(100, parseInt((event.scrollX / 633) * 100));
  },
  pushCval() { this.onVibrate(); this.lastInputChar = ""; this.hintCount = 0; const temp = this.cval; this.cval = ""; this.clearWaiting(); this.resetReslutList(); if (temp) this.addAllTxt(temp); },
  adjustScreenWidth() { device.getInfo({ success: (data) => { if (!this._isDestroyed) { this.screenWidth = data.screenWidth; } } }); },
  onTouchStart(e) { if (e.touches?.[0]) { this.touchStartY = e.touches[0].clientY; } },
  onTouchEnd(e) { if (e.changedTouches?.[0] && this.touchStartY - e.changedTouches[0].clientY > 266) { this.$emit("deleteAll", {}); } },
  onDelStart() {
    this.onBtnClick('D');
    _delTimer = setInterval(() => { this.onBtnClick('D'); }, 300);
  },
  onDelEnd() {
    if (_delTimer) { clearInterval(_delTimer); _delTimer = null; }
  }
};
</script>

<style>
